#!/bin/sh
# pre-commit hook: warn if PROJECT_TRACKER.md wasn't updated this commit.
# Non-blocking — just a reminder. Activate with:
#   git config core.hooksPath .githooks

if git diff --cached --name-only | grep -q "PROJECT_TRACKER.md"; then
  exit 0
fi

echo ""
echo "  ┌─────────────────────────────────────────────────────┐"
echo "  │  Reminder: PROJECT_TRACKER.md was not staged.       │"
echo "  │  Add an entry at the top if this is a meaningful    │"
echo "  │  change — then git add PROJECT_TRACKER.md and       │"
echo "  │  re-run git commit.  (Committing anyway…)           │"
echo "  └─────────────────────────────────────────────────────┘"
echo ""
exit 0
